# Local development can run without a model when demo mode is enabled.
DEMO_MODE=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080

# deepseek | longxia | custom
MODEL_PROVIDER=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=replace-with-your-deepseek-key
DEEPSEEK_MODEL=deepseek-v4-flash

LONGXIA_BASE_URL=https://api.longxiadev.store/v1
LONGXIA_API_KEY=replace-with-your-longxia-key
LONGXIA_MODEL=gpt-5.6-terra

# Custom OpenAI-compatible provider fallback.
MODEL_BASE_URL=
MODEL_API_KEY=
MODEL_NAME=

# Empty DATABASE_URL uses local SQLite. PostgreSQL is used when the URL starts
# with postgresql:// or postgres://.
DATABASE_URL=
DATA_DIR=
KNOWLEDGE_DIR=
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
